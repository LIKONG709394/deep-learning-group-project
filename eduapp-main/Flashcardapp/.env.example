# Poe API Configuration
# Get your API key at: https://poe.com/api_key

# Your Poe API key (required)
# Visit https://poe.com/api_key to get your key
EXPO_PUBLIC_POE_API_KEY=your_poe_api_key_here

# Poe API Base URL (optional - defaults to https://api.poe.com/v1)
EXPO_PUBLIC_POE_BASE_URL=https://api.poe.com/v1

# AI Model to use (optional - defaults to Claude-3.5-Sonnet)
# Available models: claude-sonnet-4.6 , claude-sonnet-4.5 
EXPO_PUBLIC_POE_MODEL=claude-sonnet-4.6

# ============================================
# Instructions:
# ============================================
# 1. Copy this file to create a new .env file
# 2. Replace "your_poe_api_key_here" with your actual Poe API key
# 3. Save the .env file (it's already in .gitignore - never commit it to git)
# 4. Restart the development server with: npm start
